import { useEffect, useState } from "react";
import { supabase } from "../supabase_client";

import {
    Chart as ChartJS,
    CategoryScale,
    LinearScale,
    BarElement,
    ArcElement,
    Tooltip,
    Legend
} from "chart.js";

import { Bar, Pie } from "react-chartjs-2";

// Register Chart.js components so charts can be displayed
ChartJS.register(
    CategoryScale,
    LinearScale,
    BarElement,
    ArcElement,
    Tooltip,
    Legend
);

function AnalyticsDashboard() {


    // Store data retrieved from Supabase
    const [routes, setRoutes] = useState([]);
    const [drivers, setDrivers] = useState([]);
    const [compliance, setCompliance] = useState([]);

    // Load dashboard data when the page first opens
    useEffect(() => {

        loadDashboardData();

    }, []);

    // Retrieves analytics data from Supabase tables
    async function loadDashboardData() {

        // Get route optimization information
        const { data: routeData, error: routeError } =
            await supabase
            .from("route")
            .select("*");

        if(routeError){
            console.log("Route data error:", routeError);
        }
        else{
            setRoutes(routeData);
        }


        // Get driver working hours information
        const { data: driverData, error: driverError } =
            await supabase
            .from("driver_hours")
            .select("*");

        if(driverError){
            console.log("Driver hours error:", driverError);
        }
        else{
            setDrivers(driverData);
        }

        // Get compliance statistics
        const { data: complianceData, error: complianceError } =
            await supabase
            .from("compliance_items")
            .select("*");

        if(complianceError){
            console.log("Compliance error:", complianceError);
        }
        else{
            setCompliance(complianceData);
        }

    }

    // Converts Supabase route data into a format Chart.js can display
    const routeChart = {

        labels: route.map(
            route => route.route_name
        ),

        datasets:[
            {
                label:"Distance Saved (KM)",

                data:
                route.map(
                    route => route.distance_saved
                )
            }
        ]
    };

    // Converts driver hour data into chart format
    const driverChart = {

        labels:
        drivers.map(
            driver => driver.driver_name
        ),

        datasets:[
            {
                label:"Hours Worked",

                data:
                drivers.map(
                    driver => driver.hours
                )
            }
        ]

    };

    // Converts compliance data into pie chart format
    const complianceChart = {


        labels:
        compliance.map(
            item => item.status
        ),

        datasets:[
            {

                label:"Compliance Status",

                data:
                compliance.map(
                    item => item.total
                )

            }
        ]

    };

    return (

        <div style={{padding:"30px"}}>


            <h1>
                Analytics Dashboard
            </h1>


            {/* Displays route efficiency and optimization data */}
            <div>

                <h2>
                    Route Optimization
                </h2>

                <Bar data={routeChart}/>

            </div>



            <br />

            {/* Displays driver working hours compared to workload */}
            <div>

                <h2>
                    Driver Hours
                </h2>

                <Bar data={driverChart}/>

            </div>

            <br />

            {/* Displays compliance percentage breakdown */}
            <div style={{width:"400px"}}>

                <h2>
                    Compliance
                </h2>

                <Pie data={complianceChart}/>

            </div>

        </div>

    );

}

export default AnalyticsDashboard;
